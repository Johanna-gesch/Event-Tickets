<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox styleClass="cardBox" stylesheets="@../Style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.eventtickets.GUI.Controllers.Cards.EventCardController">
    <children>
        <Label fx:id="lblName" styleClass="cardName" text="Label">
            <VBox.margin>
                <Insets bottom="5.0" />
            </VBox.margin>
        </Label>
        <Label fx:id="lblDate" styleClass="cardSub" text="Label" />
        <Label fx:id="lblTime" styleClass="cardSub" text="Label" />
        <Label fx:id="lblLocation" styleClass="cardSub" text="Label">
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
        <Label styleClass="cardSub" text="Notes:" underline="true" />
        <Label fx:id="lblNotes" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="0.0" styleClass="cardSub" text="Label" wrapText="true" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
        <Label styleClass="cardSub" text="Event Coordinator(s):" underline="true">
            <VBox.margin>
                <Insets bottom="2.0" />
            </VBox.margin>
        </Label>
        <HBox VBox.vgrow="ALWAYS">
            <children>
                <HBox fx:id="subCoordinators" spacing="5.0" HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
        <Region VBox.vgrow="ALWAYS" />
        <HBox>
            <children>
                <Region maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnEdit" alignment="BOTTOM_RIGHT" contentDisplay="RIGHT" mnemonicParsing="false" onAction="#onEdit" styleClass="btnNav" text="✐">
                    <font>
                        <Font name="Segoe UI Symbol" size="25.0" />
                    </font>
                    <padding>
                        <Insets bottom="-8.0" right="-8.0" />
                    </padding>
                </Button>
            </children>
        </HBox>
        <Separator fx:id="separator">
            <VBox.margin>
                <Insets bottom="20.0" top="20.0" />
            </VBox.margin>
        </Separator>
        <HBox fx:id="hBoxBtnDelete" alignment="CENTER" maxWidth="1.7976931348623157E308">
            <children>
                <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onDelete" prefWidth="130.0" styleClass="btnDelete" text="Delete" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
